{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window and dynamic secondary windows",
  "windows": ["main", "monica-window-*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "core:window:allow-destroy",
    "notification:default",
    "opener:default",
    "mcp-bridge:default",
    "store:default"
  ]
}
