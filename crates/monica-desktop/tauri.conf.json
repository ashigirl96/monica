{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monica",
  "version": "0.1.0",
  "identifier": "com.ashigirl96.monica",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun --bun vite build --config web/vite.config.ts && bun run build && cargo build --release -p monica-ptyd && mkdir -p crates/monica-desktop/binaries && cp target/release/monica-ptyd \"crates/monica-desktop/binaries/monica-ptyd-$(rustc -vV | sed -n 's/host: //p')\"",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monica",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "closable": false,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 22
        },
        "dragDropEnabled": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/monica/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/monica-ptyd"]
  }
}
