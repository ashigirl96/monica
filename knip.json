{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["desktop/**/*.{ts,tsx}", "extension/src/**/*.ts"],
  "entry": ["desktop/**/*.test.{ts,tsx}", "extension/src/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["lefthook", "tsc", "tauri"],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@tauri-apps/cli",
    "@tauri-apps/plugin-notification",
    "@types/chrome",
    "oxfmt",
    "oxlint"
  ]
}
