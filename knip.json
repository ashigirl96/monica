{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["src/**/*.{ts,tsx}"],
  "entry": ["src/**/*.test.{ts,tsx}"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["lefthook", "tsc", "tauri"],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@tauri-apps/cli",
    "@tauri-apps/plugin-notification",
    "oxfmt",
    "oxlint"
  ]
}
